# ========================================
# BOT ZVZ - ALBION ONLINE
# Copie este arquivo para .env e preencha
# ========================================

# Token do bot (portal de desenvolvedores Discord)
DISCORD_TOKEN=SEU_TOKEN_AQUI

# ID do cargo de Officer (quem pode criar/editar comps)
# Para pegar o ID: ative modo desenvolvedor no Discord > clique direito no cargo > Copiar ID
OFFICER_ROLE_ID=ID_DO_CARGO_OFFICER_AQUI

# ID do cargo de Caller (quem pode pingar ZvZ)
# Se deixar vazio, qualquer um com permissão pode usar /zvz ping
CALLER_ROLE_ID=ID_DO_CARGO_CALLER_AQUI
