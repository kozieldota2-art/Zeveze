function itemIdToName(itemId) {
  const clean = itemId.replace(/^T\d+_/, '').replace(/@\d+$/, '');
  return WEAPON_MAP[clean] || clean;
}

async function fetchWithTimeout(url) {
  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), TIMEOUT_MS);
  try {
    const res = await fetch(url, { signal: controller.signal });
    clearTimeout(timer);
    return res;
  } catch(e) {
    clearTimeout(timer);
    throw e;
  }
}

// Busca e salva stats de um player em background (nao bloqueia)
async function fetchAndCacheStats(userId, userName, albionName) {
  try {
    // Se cache ainda valido, nao busca de novo
    if (!db.isStatsStale(userId, CACHE_HOURS)) return;

    // Busca ID do player na API
    const searchRes = await fetchWithTimeout(ALBION_API + '/search?q=' + encodeURIComponent(albionName));
    if (!searchRes.ok) return;
    const searchData = await searchRes.json();
    const players = searchData.players || [];
    const player = players.find(p => p.Name.toLowerCase() === albionName.toLowerCase()) || players[0];
    if (!player) return;

    // Busca kills recentes
    const killsRes = await fetchWithTimeout(ALBION_API + '/players/' + player.Id + '/kills?limit=51&offset=0');
    if (!killsRes.ok) return;
    const kills = await killsRes.json();

    // Conta uso de armas
    const weaponCount = {};
    for (const kill of kills) {
      const tipo = kill?.Killer?.Equipment?.MainHand?.Type || '';
      if (!tipo) continue;
      weaponCount[tipo] = (weaponCount[tipo] || 0) + 1;
    }

    // Monta lista ordenada
    const stats = Object.entries(weaponCount)
      .sort(([,a],[,b]) => b - a)
      .slice(0, 10)
      .map(([id, count]) => ({
        id,
        name: itemIdToName(id),
        count,
        pct: Math.round(count / kills.length * 100)
      }));

    db.upsertPlayerStats(userId, userName, player.Id, stats);
    console.log('[Cache] Stats salvos para ' + userName + ' (' + stats.length + ' armas)');

  } catch(err) {
    console.log('[Cache] Erro ao buscar stats de ' + userName + ':', err.message);
  }
}

// Formata stats para exibir no Discord
function formatStats(userId, weaponName) {
  const cached = db.getPlayerStats(userId);
  if (!cached || !cached.stats?.length) return null;

  const stats = cached.stats;
  const total = stats.reduce((s, w) => s + w.count, 0);

  // Se filtrar por arma especifica
  if (weaponName) {
    const match = stats.find(w => w.name.toLowerCase().includes(weaponName.toLowerCase()));
    if (match) {
      return match.pct + '% dos kills (' + match.count + '/' + total + ')';
    }
    return '0% (sem registro)';
  }

  // Top 3 armas
  return stats.slice(0, 3).map(w => w.name + ' ' + w.pct + '%').join(' | ');
}

module.exports = { fetchAndCacheStats, formatStats, itemIdToName };
